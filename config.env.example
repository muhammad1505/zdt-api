# ZDT API Configuration
# Copy this file to config.env and adjust settings
# cp config.env.example config.env && chmod 600 config.env

# ── Storage ──────────────────────────────────────
TARGET_DIR=~/Music/ZDT_Downloads

# ── Security ─────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_generate_a_random_secret_here
ZDT_WEB_USER=admin
ZDT_WEB_PASS=change_me_generate_a_random_password_here

# ── Telegram Bot ─────────────────────────────────
# Set token to enable bot. Create via @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID (numeric). Send a message to @userinfobot to get it.
TELEGRAM_CHAT_ID=
# Set to true to auto-start bot on boot
TELEGRAM_ENABLED=false

# ── VPN (L2TP/xl2tpd) ────────────────────────────
VPN_SERVER=remote4.vpnmurahjogja.my.id
VPN_USERNAME=gemini
VPN_PASSWORD=
VPN_AUTOSTART=false

# ── Watch Daemon ─────────────────────────────────
# Auto-process new files (rename, kompres, extract vocal)
WATCH_AUTOSTART=true

# ── API Server ───────────────────────────────────
ZDT_API_PORT=2000
ZDT_API_HOST=0.0.0.0
ZDT_API_DEBUG=false

# ── Redis (optional, for multi-worker rate limiting) ──
# Jika Redis tersedia, rate limiting terpusat antar worker Gunicorn.
# Jika kosong, fallback ke in-memory (per-worker).
# Contoh dengan Redis:// tanpa password:
REDIS_URL=
# Contoh dengan password:
# REDIS_URL=redis://:password@localhost:6379/0

# ── Download Defaults ────────────────────────────
DEFAULT_FORMAT=audio
AUDIO_QUALITY=best
VIDEO_MAX_RESOLUTION=1080p
OUTPUT_NAMING_PATTERN=%(title)s.%(ext)s

# ── Notifications ────────────────────────────────
NOTIFY_ON_DOWNLOAD_COMPLETE=true
NOTIFY_ON_ERROR=true
